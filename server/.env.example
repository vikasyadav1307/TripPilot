PORT=5000

# Database Configuration - Choose ONE:
# Option 1: For Netlify Deployment
# NETLIFY_DATABASE_URL=postgresql://user:password@host/database

# Option 2: For Render/Railway/General Deployment  
# DATABASE_URL=postgresql://user:password@host/database

# Option 3: For MongoDB (Legacy)
# MONGODB_URI=mongodb://localhost:27017/trippilot

# JWT Configuration
JWT_SECRET=change_this_secret

# Google Generative AI Configuration
GEMINI_API_KEY=replace_with_your_gemini_api_key
GEMINI_MODEL=gemini-1.5-flash

# Environment
NODE_ENV=development
